{
    "settings_popup": {
        "type": "container",
        "background": "#000000",
        "margin": "6, 6",
        "content": {
            "type": "array",
            "orientation": "vertical",
            "content": [
                {
                    "type": "group",
                    "header": "Settings",
                    "content": {
                        "type": "itemgrid",
                        "item_h_alignment": "center",
                        "item_size": "24, 24",
                        "item_margin": "2, 2",
                        "rows": [
                            [
                                "setting_start",
                                "setting_logic",
                                "setting_dlc_logic",
                                "setting_costume_clip",
                                "setting_remove_it_statue",
                                "setting_life_for_hom",
                                "setting_autoscan",
                                "setting_random_research",
                                "setting_random_dissonance",
                                "setting_potsanity",
                                "setting_req_guardians",
                                "setting_req_skulls",
                                "setting_guardian_ankhs",
                                "setting_reveal_entrances",
                                "setting_show_sequence_break"
                            ]
                        ]
                    }
                },
                {
                    "type": "tabbed",
                    "tabs": [
                        {
                            "title": "Entrances",
                            "content": {
                                "type": "layout",
                                "key": "entrances_layout"
                            }
                        },
                        {
                            "title": "Escape Sequence",
                            "content": {
                                "type": "layout",
                                "key": "escape_sequence_layout"
                            }
                        },
                        {
                            "title": "References",
                            "content": {
                                "type": "layout",
                                "key": "references"
                            }
                        }
                    ]
                }
            ]
        }
    }
}
