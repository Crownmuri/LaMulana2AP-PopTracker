    "eternal_prison_reference": {
        "type": "group",
        "header": "Eternal Prison Reference",
        "content": {
            "type": "array",
            "orientation": "vertical",
            "margin": "0,0",
            "content": [
                { "type": "text", "text": "False Gates:" },
                { "type": "text", "text": "    xx:01-xx:15 Takamagahara Shrine" },
                { "type": "text", "text": "    xx:16-xx:30 Village of Departure" },
                { "type": "text", "text": "    xx:31-xx:45 Icefire Treetop" },
                { "type": "text", "text": "    xx:46-xx:60 Divine Fortress" },
                { "type": "text", "text": "Gate with Glowing Eyes:" },
                { "type": "text", "text": "    xx:01-xx:15 Ajisukitakahikone" },
                { "type": "text", "text": "Seven Gates of Hell:" },
                { "type": "text", "text": "  * Requires Hraesvelgr's gate" },
                { "type": "text", "text": "  * Don't forget the dais at [EPD D-4]" },
                { "type": "text", "text": "    -> [EPG D-2] Holy Grail (Soul Gate)" },
                { "type": "text", "text": "    -> [EPG E-1] Grapple Claw" },
                { "type": "text", "text": "    -> [EPD C-7] Gale Fibula" },
                { "type": "text", "text": "    -> [EPG D-5] Claydoll Suit" },
                { "type": "text", "text": "    -> [EPG C-6] Feather" },
                { "type": "text", "text": "    -> [EPD E-4] Anchor" },
                { "type": "text", "text": "    -> [EPD B-2] Glove" }
            ]
        }
    },
